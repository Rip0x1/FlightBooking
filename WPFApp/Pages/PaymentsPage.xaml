<Page x:Class="FlightBooking.Pages.PaymentsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="Платежи">
    <Grid Margin="20" Background="#F5F6FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <materialDesign:Card Padding="20" Margin="0,0,0,20" Background="#2196F3" Grid.Row="0">
            <materialDesign:Card.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#66000000"/>
            </materialDesign:Card.Effect>
            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                <materialDesign:PackIcon Kind="CreditCard" Width="30" Height="30" Foreground="White"/>
                <TextBlock Text="Платежи" FontSize="28" FontWeight="Bold" Foreground="White" Margin="10,0,0,0">
                    <TextBlock.RenderTransform>
                        <ScaleTransform/>
                    </TextBlock.RenderTransform>
                </TextBlock>
            </StackPanel>
        </materialDesign:Card>

        <TextBlock Grid.Row="1" Text="{Binding NotificationMessage}" FontSize="16" Foreground="Green" 
                   HorizontalAlignment="Center" Margin="0,0,0,20" 
                   Visibility="{Binding NotificationMessage, Converter={StaticResource NullToVisibilityConverter}}"/>

        <TabControl Grid.Row="2" Background="Transparent">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Background="Transparent" Padding="10,5" Margin="2">
                                    <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center"
                                                      ContentSource="Header"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="ContentSite" Property="TextElement.Foreground" Value="#2196F3"/>
                                        <Setter Property="Background" Value="#E3F2FD"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#BBDEFB"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>
            <TabItem Header="Управление платежами">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Margin="0,0,0,20" BorderBrush="#B0BEC5" BorderThickness="2" Padding="15" Background="White">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="5" ShadowDepth="1" Color="#33000000"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="Выберите бронь" FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <ComboBox ItemsSource="{Binding AvailableBookings}" 
                                      SelectedValue="{Binding NewPayment.BookingId, UpdateSourceTrigger=PropertyChanged}" 
                                      SelectedValuePath="BookingId" Width="300" Height="40" VerticalAlignment="Center" Margin="0" 
                                      Style="{StaticResource MaterialDesignComboBox}" IsEditable="False" IsReadOnly="True">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding BookingId}" Foreground="#424242"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1" Margin="0,0,0,20" BorderBrush="#B0BEC5" BorderThickness="2" Padding="15" Background="White" HorizontalAlignment="Center">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="5" ShadowDepth="1" Color="#33000000"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="Детали платежа" FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBox Text="{Binding NewPayment.Amount, StringFormat={}{0:N2}, UpdateSourceTrigger=PropertyChanged}" 
                                         Width="150" Height="40" Margin="0,0,10,0" 
                                         materialDesign:HintAssist.Hint="Сумма" Style="{StaticResource MaterialDesignTextBox}"/>
                                <TextBox Text="{Binding NewPayment.PaymentMethod}" Width="150" Height="40" Margin="0,0,10,0" 
                                         materialDesign:HintAssist.Hint="Метод оплаты" Style="{StaticResource MaterialDesignTextBox}"/>
                                <ComboBox ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding NewPayment.Status}" 
                                          Width="150" Height="40" Margin="0,0,10,0" 
                                          Style="{StaticResource MaterialDesignComboBox}" IsEditable="False">
                                    <ComboBox.ItemContainerStyle>
                                        <Style TargetType="ComboBoxItem">
                                            <Setter Property="Foreground" Value="#424242"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#E0F7FA"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ComboBox.ItemContainerStyle>
                                </ComboBox>
                                <Button Command="{Binding CreatePaymentCommand}" Style="{StaticResource MaterialDesignRaisedButton}" 
                                        Width="150" Height="40" Background="#4CAF50" Foreground="White" Margin="0,0,10,0">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <materialDesign:PackIcon Kind="Plus" Width="16" Height="16" Margin="0,0,5,0"/>
                                        <TextBlock Text="Создать"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding EditPaymentCommand}" Style="{StaticResource MaterialDesignRaisedButton}" 
                                        Width="150" Height="40" Background="#FF9800" Foreground="White" Margin="0,0,10,0" 
                                        IsEnabled="{Binding SelectedPayment, Converter={StaticResource NullToBoolConverter}}">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <materialDesign:PackIcon Kind="Pencil" Width="16" Height="16" Margin="0,0,5,0"/>
                                        <TextBlock Text="Редактировать"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding DeletePaymentCommand}" Style="{StaticResource MaterialDesignRaisedButton}" 
                                        Width="150" Height="40" Background="#F44336" Foreground="White" Margin="0,0,10,0" 
                                        IsEnabled="{Binding SelectedPayment, Converter={StaticResource NullToBoolConverter}}">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <materialDesign:PackIcon Kind="Delete" Width="16" Height="16" Margin="0,0,5,0"/>
                                        <TextBlock Text="Удалить"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding ExportToExcelCommand}" Style="{StaticResource MaterialDesignRaisedButton}" 
                                        Width="150" Height="40" Background="#9E9E9E" Foreground="White" Margin="0,0,0,0">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <materialDesign:PackIcon Kind="FileExcel" Width="16" Height="16" Margin="0,0,5,0"/>
                                        <TextBlock Text="Экспорт в Excel"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
            <TabItem Header="Список платежей">
                <Grid>
                    <Border Padding="15" BorderBrush="#B0BEC5" BorderThickness="2" Background="White" HorizontalAlignment="Center">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="5" ShadowDepth="1" Color="#33000000"/>
                        </Border.Effect>
                        <ListView ItemsSource="{Binding Payments}" SelectedItem="{Binding SelectedPayment}" MaxHeight="400">
                            <ListView.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Opacity)" From="0" To="1" Duration="0:0:0.5"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </ListView.Triggers>
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="ID Платежа" DisplayMemberBinding="{Binding PaymentId}" Width="Auto"/>
                                    <GridViewColumn Header="Номер брони" DisplayMemberBinding="{Binding BookingId}" Width="Auto"/>
                                    <GridViewColumn Header="Сумма" DisplayMemberBinding="{Binding Amount, StringFormat={}{0:C}}" Width="Auto"/>
                                    <GridViewColumn Header="Дата" DisplayMemberBinding="{Binding PaymentDate, StringFormat={}{0:dd/MM/yyyy HH:mm}}" Width="Auto"/>
                                    <GridViewColumn Header="Метод" DisplayMemberBinding="{Binding PaymentMethod}" Width="Auto"/>
                                    <GridViewColumn Header="Статус" DisplayMemberBinding="{Binding Status}" Width="Auto"/>
                                </GridView>
                            </ListView.View>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#E3F2FD"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#BBDEFB"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>